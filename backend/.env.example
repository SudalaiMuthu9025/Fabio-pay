# Fabio Backend — Environment Variables
# Copy to .env and fill in production values

DATABASE_URL=postgresql+asyncpg://fabio:fabio@localhost:5432/fabio_db
SECRET_KEY=CHANGE-ME-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
EAR_THRESHOLD=0.2
MAR_THRESHOLD=0.5
CHALLENGE_COUNT=3
PANIC_TIMER_SECONDS=15
DEBUG=true
