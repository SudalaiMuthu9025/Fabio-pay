# Fabio Backend — Environment Variables
# Copy to .env and fill in production values.
# Generate SECRET_KEY with: openssl rand -hex 32

DATABASE_URL=postgresql+asyncpg://fabio:fabio@localhost:5432/fabio_db
SECRET_KEY=CHANGE-ME-use-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=1440
SESSION_EXPIRE_HOURS=24

# Transaction security
TRANSACTION_THRESHOLD=5000.00

# Face recognition
FACE_MATCH_THRESHOLD=0.35

# Liveness challenge tuning
EAR_THRESHOLD=0.20
MAR_THRESHOLD=0.50
CHALLENGE_COUNT=3
PANIC_TIMER_SECONDS=15

# App
DEBUG=true
ALLOWED_ORIGINS=*
